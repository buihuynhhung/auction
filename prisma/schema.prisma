generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum ItemCategory {
  ELECTRONICS
  FASHION
  HOME
  COLLECTIBLE
  VEHICLE
  BOOK
  LAPTOP
  PRINTER
  SCANNER
  MONITOR
  ACCESSORY
  OTHER
}

enum ItemCondition {
  GOOD
  FAIR
  AVERAGE
  PARTIALLY_BROKEN
  OTHER
}

enum ItemStatus {
  DRAFT
  AVAILABLE
  ARCHIVED
}

enum AuctionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  CLOSED
  CANCELLED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(EMPLOYEE)
  department   String?
  isActive     Boolean   @default(true)
  sellerPlanActive Boolean @default(false)
  sellerPlanExpiresAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdItems    Item[]      @relation("ItemCreatedBy")
  createdAuctions Auction[]   @relation("AuctionCreatedBy")
  bids            Bid[]
  wonAuctions     Auction[]   @relation("AuctionWinner")
}

model Item {
  id                  String        @id @default(cuid())
  name                String
  category            ItemCategory
  assetCode           String?       @unique
  serialNumber        String?
  model               String?
  description         String?
  publicInfo          String?
  condition           ItemCondition @default(OTHER)
  includedAccessories String?
  knownIssues         String?
  status              ItemStatus    @default(DRAFT)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  createdById String
  createdBy   User        @relation("ItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  images      ItemImage[]
  auctions    Auction[]

  @@index([category])
  @@index([status])
}

model ItemImage {
  id        String   @id @default(cuid())
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, sortOrder])
  @@unique([itemId, sortOrder])
}

model Auction {
  id            String        @id @default(cuid())
  startingPrice Decimal       @db.Decimal(12, 2)
  minIncrement  Decimal       @db.Decimal(12, 2)
  startAt       DateTime
  endAt         DateTime
  status        AuctionStatus @default(DRAFT)
  closedAt      DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  itemId      String
  item        Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User   @relation("AuctionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  winnerId    String?
  winner      User?  @relation("AuctionWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  winningBidId String? @unique
  winningBid   Bid?   @relation("AuctionWinningBid", fields: [winningBidId], references: [id], onDelete: SetNull)
  bids        Bid[]

  @@index([status, startAt, endAt])
  @@index([status, endAt])
  @@index([itemId, status])
  @@index([itemId, startAt, endAt])
  @@index([winnerId])
  @@index([createdById, createdAt])
}

model Bid {
  id        String   @id @default(cuid())
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  auctionId String
  auction   Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  winningAuction Auction? @relation("AuctionWinningBid")

  @@index([auctionId, amount, createdAt])
  @@index([auctionId, amount])
  @@index([auctionId, createdAt])
  @@index([userId])
}
